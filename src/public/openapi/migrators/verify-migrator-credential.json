{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/migrators/verify-cred": {
      "post": {
        "operationId": "verifyMigratorCredential",
        "summary": "POST Verify Migrator Credential",
        "description": "Verify the API credentials for a specific CRM migrator driver. Tests the provided credentials against the external CRM service to confirm they are valid before proceeding with the migration.",
        "tags": [
          "Migrators"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "driver",
                  "credential"
                ],
                "properties": {
                  "driver": {
                    "type": "string",
                    "description": "Migrator driver identifier (e.g., `mailchimp`, `ConvertKit`, `MailerLite`, `Drip`, `ActiveCampaign`)."
                  },
                  "credential": {
                    "type": "object",
                    "description": "Driver-specific credential fields (e.g., API key, API secret).",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              },
              "example": {
                "driver": "mailchimp",
                "credential": {
                  "api_key": "abc123def456-us10"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Credentials verified successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message."
                    }
                  }
                },
                "example": {
                  "message": "Your provided API key is valid"
                }
              }
            }
          },
          "422": {
            "description": "Invalid credentials or driver not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Sorry no driver found for the selected CRM"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}