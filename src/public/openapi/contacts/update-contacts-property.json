{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/subscribers/subscribers-property": {
      "put": {
        "operationId": "updateContactsProperty",
        "summary": "PUT Update Contacts Property",
        "description": "Update a single property for one or more contacts. Supported properties are `status`, `contact_type`, `avatar`, `company_id`, and `sms_status`. Validates the value against allowed options for each property type.",
        "tags": [
          "Contacts"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "property",
                  "value",
                  "subscribers"
                ],
                "properties": {
                  "property": {
                    "type": "string",
                    "enum": [
                      "status",
                      "contact_type",
                      "avatar",
                      "company_id",
                      "sms_status"
                    ],
                    "description": "The property/column to update."
                  },
                  "value": {
                    "type": "string",
                    "description": "The new value for the property. Must be valid for the given property type (e.g., `subscribed` for status, `lead`/`customer` for contact_type)."
                  },
                  "subscribers": {
                    "oneOf": [
                      {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        }
                      },
                      {
                        "type": "integer"
                      }
                    ],
                    "description": "Contact ID(s) to update. Can be a single ID or an array of IDs."
                  }
                }
              },
              "example": {
                "property": "status",
                "value": "subscribed",
                "subscribers": [
                  1,
                  5,
                  12
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contacts updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Subscribers successfully updated"
                }
              }
            }
          },
          "422": {
            "description": "Validation error (invalid column or value).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Column is not valid"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}