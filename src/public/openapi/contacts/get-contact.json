{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/subscribers/{id}": {
      "get": {
        "operationId": "getContact",
        "summary": "GET Get Contact",
        "description": "Retrieve a single contact by ID or email. Supports eager-loading related data like stats, custom values, custom field definitions, and commerce stats via the `with[]` parameter.",
        "tags": [
          "Contacts"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The contact ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "get_by_email",
            "in": "query",
            "description": "If set, looks up the contact by email address instead of the path `id`.",
            "required": false,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "with[]",
            "in": "query",
            "description": "Relationships and extra data to include. Supported values: `stats`, `subscriber.custom_values`, `custom_fields`, `commerce_stat`.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "stats",
                  "subscriber.custom_values",
                  "custom_fields",
                  "commerce_stat"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscriber": {
                      "allOf": [
                        {
                          "$ref": "#/components/schemas/Contact"
                        },
                        {
                          "type": "object",
                          "properties": {
                            "user_edit_url": {
                              "type": "string",
                              "description": "WordPress user edit URL (if linked to a WP user)."
                            },
                            "user_roles": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "description": "WordPress user roles (if linked to a WP user)."
                            },
                            "custom_values": {
                              "type": "object",
                              "description": "Custom field values (only when `with[]` includes `subscriber.custom_values`).",
                              "additionalProperties": {
                                "type": "string"
                              }
                            },
                            "commerce_stat": {
                              "type": [
                                "object",
                                "array"
                              ],
                              "description": "Commerce statistics (only when `with[]` includes `commerce_stat` and a commerce provider is active)."
                            },
                            "unsubscribe_reason": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Reason for unsubscribe (only for unsubscribed/bounced/complained contacts)."
                            },
                            "unsubscribe_date": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "description": "Date of unsubscribe (only for unsubscribed/bounced/complained contacts)."
                            }
                          }
                        }
                      ]
                    },
                    "custom_fields": {
                      "type": "array",
                      "description": "Custom field definitions (only when `with[]` includes `custom_fields`).",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "slug": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "subscriber": {
                    "id": 1,
                    "user_id": "5",
                    "hash": "a1b2c3d4e5f6",
                    "contact_owner": null,
                    "company_id": null,
                    "prefix": "Mr",
                    "first_name": "John",
                    "last_name": "Doe",
                    "full_name": "John Doe",
                    "email": "john@example.com",
                    "status": "subscribed",
                    "contact_type": "customer",
                    "address_line_1": "123 Main St",
                    "address_line_2": "",
                    "postal_code": "90210",
                    "city": "Beverly Hills",
                    "state": "CA",
                    "country": "US",
                    "phone": "+1234567890",
                    "timezone": "America/New_York",
                    "date_of_birth": "1990-05-15",
                    "source": "web",
                    "life_time_value": 0,
                    "last_activity": "2024-03-01 14:30:00",
                    "total_points": 0,
                    "latitude": null,
                    "longitude": null,
                    "ip": "192.168.1.1",
                    "created_at": "2024-01-15 10:30:00",
                    "updated_at": "2024-03-01 14:30:00",
                    "photo": "https://www.gravatar.com/avatar/abc123",
                    "user_edit_url": "https://example.com/wp-admin/user-edit.php?user_id=5",
                    "user_roles": [
                      "subscriber"
                    ],
                    "tags": [
                      {
                        "id": 1,
                        "title": "VIP Customer",
                        "slug": "vip-customer"
                      }
                    ],
                    "lists": [
                      {
                        "id": 1,
                        "title": "Newsletter",
                        "slug": "newsletter"
                      }
                    ],
                    "stats": {
                      "emails": 25,
                      "opens": 18,
                      "clicks": 7,
                      "total_points": 150,
                      "last_activity": "2024-03-01 14:30:00"
                    },
                    "custom_values": {
                      "company_name": "Acme Inc",
                      "job_title": "Developer"
                    }
                  },
                  "custom_fields": [
                    {
                      "label": "Company Name",
                      "slug": "company_name",
                      "type": "text"
                    },
                    {
                      "label": "Job Title",
                      "slug": "job_title",
                      "type": "text"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Contact not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Subscriber not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the contact."
          },
          "user_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Associated WordPress user ID."
          },
          "hash": {
            "type": "string",
            "description": "Unique hash for the contact."
          },
          "contact_owner": {
            "type": [
              "string",
              "null"
            ],
            "description": "User ID of the contact owner."
          },
          "company_id": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Primary company ID."
          },
          "prefix": {
            "type": [
              "string",
              "null"
            ],
            "description": "Name prefix (e.g., Mr, Mrs, Ms)."
          },
          "first_name": {
            "type": "string",
            "description": "Contact first name."
          },
          "last_name": {
            "type": "string",
            "description": "Contact last name."
          },
          "full_name": {
            "type": "string",
            "description": "Full name (computed from first_name and last_name)."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email address."
          },
          "status": {
            "type": "string",
            "enum": [
              "subscribed",
              "pending",
              "unsubscribed",
              "bounced",
              "complained"
            ],
            "description": "Contact subscription status."
          },
          "contact_type": {
            "type": "string",
            "enum": [
              "lead",
              "customer"
            ],
            "description": "Contact type."
          },
          "address_line_1": {
            "type": [
              "string",
              "null"
            ],
            "description": "Address line 1."
          },
          "address_line_2": {
            "type": [
              "string",
              "null"
            ],
            "description": "Address line 2."
          },
          "postal_code": {
            "type": [
              "string",
              "null"
            ],
            "description": "Postal/zip code."
          },
          "city": {
            "type": [
              "string",
              "null"
            ],
            "description": "City."
          },
          "state": {
            "type": [
              "string",
              "null"
            ],
            "description": "State or province."
          },
          "country": {
            "type": [
              "string",
              "null"
            ],
            "description": "Two-letter country code."
          },
          "ip": {
            "type": [
              "string",
              "null"
            ],
            "description": "IP address."
          },
          "latitude": {
            "type": [
              "number",
              "null"
            ],
            "description": "Latitude coordinate."
          },
          "longitude": {
            "type": [
              "number",
              "null"
            ],
            "description": "Longitude coordinate."
          },
          "phone": {
            "type": [
              "string",
              "null"
            ],
            "description": "Phone number."
          },
          "timezone": {
            "type": [
              "string",
              "null"
            ],
            "description": "Timezone identifier."
          },
          "date_of_birth": {
            "type": [
              "string",
              "null"
            ],
            "description": "Date of birth (YYYY-MM-DD)."
          },
          "source": {
            "type": [
              "string",
              "null"
            ],
            "description": "Source of the contact."
          },
          "life_time_value": {
            "type": "number",
            "description": "Lifetime value of the contact."
          },
          "last_activity": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "Timestamp of last activity."
          },
          "total_points": {
            "type": "integer",
            "description": "Total engagement points."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the contact was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the contact was last updated."
          },
          "photo": {
            "type": "string",
            "description": "Gravatar URL."
          },
          "tags": {
            "type": "array",
            "description": "Tags assigned to the contact.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                }
              }
            }
          },
          "lists": {
            "type": "array",
            "description": "Lists the contact belongs to.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                }
              }
            }
          },
          "stats": {
            "type": "object",
            "description": "Contact statistics (only included when requested via `with[]` parameter).",
            "properties": {
              "emails": {
                "type": "integer"
              },
              "opens": {
                "type": "integer"
              },
              "clicks": {
                "type": "integer"
              },
              "total_points": {
                "type": "integer"
              },
              "last_activity": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}