{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/subscribers/sync-segments": {
      "post": {
        "operationId": "syncContactSegments",
        "summary": "POST Sync Contact Segments",
        "description": "Attach and/or detach tags or lists for one or more contacts in a single request. The `type` parameter controls whether tags or lists are being synced.",
        "tags": [
          "Contacts"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "subscribers",
                  "type"
                ],
                "properties": {
                  "subscribers": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of contact IDs to update."
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "tags",
                      "lists"
                    ],
                    "description": "Whether to sync tags or lists."
                  },
                  "attach": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Slugs (or values matching `find_by`) of tags/lists to attach."
                  },
                  "detach": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Slugs (or values matching `find_by`) of tags/lists to detach."
                  },
                  "find_by": {
                    "type": "string",
                    "default": "slug",
                    "description": "Column to match attach/detach values against (e.g., `slug`, `id`, `title`)."
                  }
                }
              },
              "example": {
                "subscribers": [
                  1,
                  5,
                  12
                ],
                "type": "tags",
                "attach": [
                  "vip-customer",
                  "newsletter-subscriber"
                ],
                "detach": [
                  "trial-user"
                ],
                "find_by": "slug"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Segments synced successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "subscribers": {
                      "type": "array",
                      "description": "Updated contacts with their tags and lists.",
                      "items": {
                        "$ref": "#/components/schemas/Contact"
                      }
                    }
                  }
                },
                "example": {
                  "message": "Successfully updated the subscribers.",
                  "subscribers": [
                    {
                      "id": 1,
                      "email": "john@example.com",
                      "first_name": "John",
                      "last_name": "Doe",
                      "tags": [
                        {
                          "id": 1,
                          "title": "VIP Customer",
                          "slug": "vip-customer"
                        },
                        {
                          "id": 2,
                          "title": "Newsletter Subscriber",
                          "slug": "newsletter-subscriber"
                        }
                      ],
                      "lists": [
                        {
                          "id": 1,
                          "title": "Newsletter",
                          "slug": "newsletter"
                        }
                      ]
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the contact."
          },
          "user_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Associated WordPress user ID."
          },
          "hash": {
            "type": "string",
            "description": "Unique hash for the contact."
          },
          "contact_owner": {
            "type": [
              "string",
              "null"
            ],
            "description": "User ID of the contact owner."
          },
          "company_id": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Primary company ID."
          },
          "prefix": {
            "type": [
              "string",
              "null"
            ],
            "description": "Name prefix (e.g., Mr, Mrs, Ms)."
          },
          "first_name": {
            "type": "string",
            "description": "Contact first name."
          },
          "last_name": {
            "type": "string",
            "description": "Contact last name."
          },
          "full_name": {
            "type": "string",
            "description": "Full name (computed from first_name and last_name)."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email address."
          },
          "status": {
            "type": "string",
            "enum": [
              "subscribed",
              "pending",
              "unsubscribed",
              "bounced",
              "complained"
            ],
            "description": "Contact subscription status."
          },
          "contact_type": {
            "type": "string",
            "enum": [
              "lead",
              "customer"
            ],
            "description": "Contact type."
          },
          "address_line_1": {
            "type": [
              "string",
              "null"
            ],
            "description": "Address line 1."
          },
          "address_line_2": {
            "type": [
              "string",
              "null"
            ],
            "description": "Address line 2."
          },
          "postal_code": {
            "type": [
              "string",
              "null"
            ],
            "description": "Postal/zip code."
          },
          "city": {
            "type": [
              "string",
              "null"
            ],
            "description": "City."
          },
          "state": {
            "type": [
              "string",
              "null"
            ],
            "description": "State or province."
          },
          "country": {
            "type": [
              "string",
              "null"
            ],
            "description": "Two-letter country code."
          },
          "ip": {
            "type": [
              "string",
              "null"
            ],
            "description": "IP address."
          },
          "latitude": {
            "type": [
              "number",
              "null"
            ],
            "description": "Latitude coordinate."
          },
          "longitude": {
            "type": [
              "number",
              "null"
            ],
            "description": "Longitude coordinate."
          },
          "phone": {
            "type": [
              "string",
              "null"
            ],
            "description": "Phone number."
          },
          "timezone": {
            "type": [
              "string",
              "null"
            ],
            "description": "Timezone identifier."
          },
          "date_of_birth": {
            "type": [
              "string",
              "null"
            ],
            "description": "Date of birth (YYYY-MM-DD)."
          },
          "source": {
            "type": [
              "string",
              "null"
            ],
            "description": "Source of the contact."
          },
          "life_time_value": {
            "type": "number",
            "description": "Lifetime value of the contact."
          },
          "last_activity": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "Timestamp of last activity."
          },
          "total_points": {
            "type": "integer",
            "description": "Total engagement points."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the contact was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the contact was last updated."
          },
          "photo": {
            "type": "string",
            "description": "Gravatar URL."
          },
          "tags": {
            "type": "array",
            "description": "Tags assigned to the contact.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                }
              }
            }
          },
          "lists": {
            "type": "array",
            "description": "Lists the contact belongs to.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                },
                "slug": {
                  "type": "string"
                }
              }
            }
          },
          "stats": {
            "type": "object",
            "description": "Contact statistics (only included when requested via `with[]` parameter).",
            "properties": {
              "emails": {
                "type": "integer"
              },
              "opens": {
                "type": "integer"
              },
              "clicks": {
                "type": "integer"
              },
              "total_points": {
                "type": "integer"
              },
              "last_activity": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}