{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/companies/custom-fields": {
      "get": {
        "operationId": "getCompanyCustomFields",
        "summary": "GET Get Company Custom Fields",
        "description": "Retrieve the global custom field definitions for companies. These define the custom fields available for all companies (not the values for a specific company).",
        "tags": [
          "Companies"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "with[]",
            "in": "query",
            "description": "Additional data to include with the fields.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Custom field definitions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fields": {
                      "type": "array",
                      "description": "Array of custom field definitions.",
                      "items": {
                        "$ref": "#/components/schemas/CustomCompanyField"
                      }
                    }
                  }
                },
                "example": {
                  "fields": [
                    {
                      "key": "annual_revenue",
                      "label": "Annual Revenue",
                      "type": "number",
                      "options": [],
                      "settings": {}
                    },
                    {
                      "key": "contract_end_date",
                      "label": "Contract End Date",
                      "type": "date",
                      "options": [],
                      "settings": {}
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "CustomCompanyField": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique field key/slug."
          },
          "label": {
            "type": "string",
            "description": "Human-readable field label."
          },
          "type": {
            "type": "string",
            "description": "Field input type.",
            "enum": [
              "text",
              "textarea",
              "number",
              "date",
              "select",
              "radio",
              "checkbox"
            ]
          },
          "options": {
            "type": "array",
            "description": "Available options for select/radio/checkbox fields.",
            "items": {
              "type": "string"
            }
          },
          "settings": {
            "type": "object",
            "description": "Additional field settings."
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}