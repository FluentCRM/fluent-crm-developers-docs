{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/companies/{id}": {
      "put": {
        "operationId": "updateCompany",
        "summary": "PUT Update Company",
        "description": "Update an existing company. The company name must remain unique across all companies. If the `id` is `0`, the request is treated as a create operation. URL fields (`website`, `linkedin_url`, `facebook_url`, `twitter_url`) are auto-prefixed with `https://` if no scheme is provided and validated as URLs.",
        "tags": [
          "Companies"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The company ID to update. Pass `0` to create a new company instead.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Company name (must be unique)."
                  },
                  "description": {
                    "type": "string",
                    "description": "Company description."
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Company email address."
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number."
                  },
                  "address_line_1": {
                    "type": "string",
                    "description": "Address line 1."
                  },
                  "address_line_2": {
                    "type": "string",
                    "description": "Address line 2."
                  },
                  "city": {
                    "type": "string",
                    "description": "City."
                  },
                  "state": {
                    "type": "string",
                    "description": "State or province."
                  },
                  "postal_code": {
                    "type": "string",
                    "description": "Postal/zip code."
                  },
                  "country": {
                    "type": "string",
                    "description": "Two-letter country code."
                  },
                  "type": {
                    "type": "string",
                    "description": "Company type (e.g., partner, customer, vendor)."
                  },
                  "industry": {
                    "type": "string",
                    "description": "Industry category."
                  },
                  "logo": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to the company logo image."
                  },
                  "website": {
                    "type": "string",
                    "format": "uri",
                    "description": "Company website URL."
                  },
                  "linkedin_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "LinkedIn profile URL."
                  },
                  "facebook_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Facebook page URL."
                  },
                  "twitter_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Twitter/X profile URL."
                  },
                  "owner_user_id": {
                    "type": "integer",
                    "description": "Subscriber ID of the company owner."
                  },
                  "employees_number": {
                    "type": "integer",
                    "description": "Number of employees."
                  },
                  "status": {
                    "type": "string",
                    "description": "Company status."
                  }
                }
              },
              "example": {
                "name": "Acme Corporation",
                "email": "contact@acme.com",
                "employees_number": 300,
                "type": "partner"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Company updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "company": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Unique identifier for the company."
                        },
                        "name": {
                          "type": "string",
                          "description": "Company name."
                        },
                        "description": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Company description."
                        },
                        "email": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "email",
                          "description": "Company email address."
                        },
                        "phone": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Phone number."
                        },
                        "address_line_1": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Address line 1."
                        },
                        "address_line_2": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Address line 2."
                        },
                        "city": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "City."
                        },
                        "state": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "State or province."
                        },
                        "postal_code": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Postal/zip code."
                        },
                        "country": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Two-letter country code."
                        },
                        "type": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Company type (e.g., partner, customer, vendor)."
                        },
                        "industry": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Industry category."
                        },
                        "logo": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "URL to the company logo image."
                        },
                        "website": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "uri",
                          "description": "Company website URL."
                        },
                        "linkedin_url": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "uri",
                          "description": "LinkedIn profile URL."
                        },
                        "facebook_url": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "uri",
                          "description": "Facebook page URL."
                        },
                        "twitter_url": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "uri",
                          "description": "Twitter/X profile URL."
                        },
                        "owner_user_id": {
                          "type": [
                            "integer",
                            "null"
                          ],
                          "description": "Subscriber ID of the company owner."
                        },
                        "employees_number": {
                          "type": [
                            "integer",
                            "null"
                          ],
                          "description": "Number of employees."
                        },
                        "status": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Company status."
                        },
                        "contacts_count": {
                          "type": "integer",
                          "description": "Number of contacts associated with this company."
                        },
                        "created_at": {
                          "type": "string",
                          "format": "date-time",
                          "description": "Timestamp when the company was created."
                        },
                        "updated_at": {
                          "type": "string",
                          "format": "date-time",
                          "description": "Timestamp when the company was last updated."
                        },
                        "owner": {
                          "type": [
                            "object",
                            "null"
                          ],
                          "description": "The contact who owns this company.",
                          "properties": {
                            "id": {
                              "type": "integer"
                            },
                            "first_name": {
                              "type": "string"
                            },
                            "last_name": {
                              "type": "string"
                            },
                            "email": {
                              "type": "string",
                              "format": "email"
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "message": "Company has been updated",
                  "company": {
                    "id": 1,
                    "name": "Acme Corporation",
                    "email": "contact@acme.com",
                    "employees_number": 300,
                    "type": "partner",
                    "created_at": "2024-01-15 10:30:00",
                    "updated_at": "2024-03-05 09:15:00"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Company not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error (e.g., duplicate company name, invalid URL).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}