{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/recurring-campaigns/{campaign_id}/emails/{email_id}": {
      "get": {
        "operationId": "getRecurringCampaignEmail",
        "summary": "GET Get Recurring Campaign Email",
        "description": "Retrieve a single child email from a recurring campaign. Returns both the parent recurring campaign and the specific email. If the email has a `scheduled` status and its scheduled time has passed, its status is automatically updated to `working`. Requires FluentCampaign Pro.",
        "tags": [
          "Recurring Campaigns"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "description": "The parent recurring campaign ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "email_id",
            "in": "path",
            "description": "The child email ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recurring campaign email details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaign": {
                      "$ref": "#/components/schemas/RecurringCampaign"
                    },
                    "email": {
                      "$ref": "#/components/schemas/RecurringMail"
                    }
                  }
                },
                "example": {
                  "campaign": {
                    "id": 5,
                    "title": "Weekly Newsletter",
                    "status": "active",
                    "type": "recurring_campaign",
                    "created_at": "2024-03-01 10:00:00",
                    "updated_at": "2024-03-25 11:00:00"
                  },
                  "email": {
                    "id": 20,
                    "parent_id": 5,
                    "title": "Weekly Newsletter",
                    "slug": "weekly-newsletter-20240325",
                    "type": "recurring_mail",
                    "status": "sent",
                    "email_subject": "Your Weekly Update - March 25",
                    "email_pre_header": "",
                    "email_body": "<p>Hello {{contact.first_name}}</p>",
                    "recipients_count": 150,
                    "design_template": "simple",
                    "scheduled_at": "2024-03-25 09:00:00",
                    "settings": {
                      "mailer_settings": {
                        "from_name": "",
                        "from_email": "",
                        "reply_to_name": "",
                        "reply_to_email": "",
                        "is_custom": "no"
                      }
                    },
                    "created_at": "2024-03-25 08:00:00",
                    "updated_at": "2024-03-25 09:30:00"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Recurring campaign or email not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "RecurringCampaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the recurring campaign."
          },
          "title": {
            "type": "string",
            "description": "Campaign title."
          },
          "slug": {
            "type": "string",
            "description": "URL-friendly slug derived from the title."
          },
          "status": {
            "type": "string",
            "description": "Campaign status.",
            "enum": [
              "draft",
              "active"
            ]
          },
          "type": {
            "type": "string",
            "description": "Record type (always `recurring_campaign`).",
            "enum": [
              "recurring_campaign"
            ]
          },
          "template_id": {
            "type": "integer",
            "nullable": true,
            "description": "Associated email template ID."
          },
          "email_subject": {
            "type": "string",
            "description": "Email subject line."
          },
          "email_pre_header": {
            "type": "string",
            "description": "Email pre-header text."
          },
          "email_body": {
            "type": "string",
            "description": "Email body content (HTML)."
          },
          "recipients_count": {
            "type": "integer",
            "description": "Number of recipients."
          },
          "utm_status": {
            "type": "integer",
            "description": "Whether UTM tracking is enabled (1 = enabled, 0 = disabled)."
          },
          "utm_source": {
            "type": "string",
            "description": "UTM source parameter."
          },
          "utm_medium": {
            "type": "string",
            "description": "UTM medium parameter."
          },
          "utm_campaign": {
            "type": "string",
            "description": "UTM campaign parameter."
          },
          "utm_term": {
            "type": "string",
            "description": "UTM term parameter."
          },
          "utm_content": {
            "type": "string",
            "description": "UTM content parameter."
          },
          "design_template": {
            "type": "string",
            "description": "Design template for the campaign (e.g., `simple`, `visual_builder`)."
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Next scheduled send date/time."
          },
          "settings": {
            "type": "object",
            "description": "Campaign settings including scheduling, sending conditions, subscriber targeting, and mailer configuration.",
            "properties": {
              "mailer_settings": {
                "type": "object",
                "properties": {
                  "from_name": {
                    "type": "string",
                    "description": "Sender name."
                  },
                  "from_email": {
                    "type": "string",
                    "description": "Sender email address."
                  },
                  "reply_to_name": {
                    "type": "string",
                    "description": "Reply-to name."
                  },
                  "reply_to_email": {
                    "type": "string",
                    "description": "Reply-to email address."
                  },
                  "is_custom": {
                    "type": "string",
                    "description": "Whether custom mailer settings are enabled.",
                    "enum": [
                      "yes",
                      "no"
                    ]
                  }
                }
              },
              "scheduling_settings": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Schedule type.",
                    "enum": [
                      "daily",
                      "weekly",
                      "monthly",
                      "yearly"
                    ]
                  },
                  "day": {
                    "type": "string",
                    "description": "Day for weekly schedules (e.g., `mon`, `tue`)."
                  },
                  "time": {
                    "type": "string",
                    "description": "Time of day (e.g., `09.00`)."
                  },
                  "send_automatically": {
                    "type": "string",
                    "description": "Whether to send automatically or create drafts for review.",
                    "enum": [
                      "yes",
                      "no"
                    ]
                  }
                }
              },
              "sending_conditions": {
                "type": "array",
                "description": "Conditions that must be met before sending.",
                "items": {
                  "type": "object"
                }
              },
              "subscribers_settings": {
                "type": "object",
                "description": "Subscriber targeting settings.",
                "properties": {
                  "subscribers": {
                    "type": "array",
                    "description": "Included subscriber segments.",
                    "items": {
                      "type": "object"
                    }
                  },
                  "excludedSubscribers": {
                    "type": "array",
                    "description": "Excluded subscriber segments.",
                    "items": {
                      "type": "object"
                    }
                  },
                  "sending_filter": {
                    "type": "string",
                    "description": "Filter type for subscriber selection."
                  },
                  "dynamic_segment": {
                    "type": "object",
                    "description": "Dynamic segment configuration."
                  },
                  "advanced_filters": {
                    "type": "array",
                    "description": "Advanced filter conditions.",
                    "items": {
                      "type": "array"
                    }
                  }
                }
              },
              "template_config": {
                "type": "object",
                "description": "Template configuration."
              }
            }
          },
          "created_by": {
            "type": "integer",
            "description": "WordPress user ID of the creator."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the campaign was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the campaign was last updated."
          }
        }
      },
      "RecurringMail": {
        "type": "object",
        "description": "A child email campaign generated by a recurring campaign.",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the recurring mail."
          },
          "parent_id": {
            "type": "integer",
            "description": "Parent recurring campaign ID."
          },
          "title": {
            "type": "string",
            "description": "Email title."
          },
          "slug": {
            "type": "string",
            "description": "URL-friendly slug."
          },
          "type": {
            "type": "string",
            "description": "Record type (always `recurring_mail`).",
            "enum": [
              "recurring_mail"
            ]
          },
          "status": {
            "type": "string",
            "description": "Email status.",
            "enum": [
              "draft",
              "scheduled",
              "pending-scheduled",
              "working",
              "sent",
              "cancelled"
            ]
          },
          "template_id": {
            "type": "integer",
            "nullable": true,
            "description": "Template ID."
          },
          "email_subject": {
            "type": "string",
            "description": "Email subject line."
          },
          "email_pre_header": {
            "type": "string",
            "description": "Email pre-header text."
          },
          "email_body": {
            "type": "string",
            "description": "Email body content (HTML)."
          },
          "recipients_count": {
            "type": "integer",
            "description": "Number of recipients."
          },
          "design_template": {
            "type": "string",
            "description": "Design template used."
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Scheduled send time."
          },
          "settings": {
            "type": "object",
            "description": "Email settings including mailer configuration and subscriber targeting.",
            "properties": {
              "mailer_settings": {
                "type": "object",
                "properties": {
                  "from_name": {
                    "type": "string"
                  },
                  "from_email": {
                    "type": "string"
                  },
                  "reply_to_name": {
                    "type": "string"
                  },
                  "reply_to_email": {
                    "type": "string"
                  },
                  "is_custom": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ]
                  }
                }
              }
            }
          },
          "created_by": {
            "type": "integer",
            "description": "WordPress user ID of the creator."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the email was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the email was last updated."
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}