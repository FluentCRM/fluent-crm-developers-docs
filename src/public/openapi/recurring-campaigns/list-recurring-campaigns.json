{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/recurring-campaigns": {
      "get": {
        "operationId": "listRecurringCampaigns",
        "summary": "GET List Recurring Campaigns",
        "description": "Retrieve a paginated list of recurring email campaigns. Supports filtering by search term and labels, and sorting by column and direction. Each campaign includes an `emails_count` of child mail campaigns and formatted labels. If the campaign is active with manual sending, a `has_draft` flag indicates whether a draft email exists. Requires FluentCampaign Pro.",
        "tags": [
          "Recurring Campaigns"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search recurring campaigns by title.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "desc",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "name": "orderBy",
            "in": "query",
            "description": "Column to sort by.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "id"
            }
          },
          {
            "name": "labels[]",
            "in": "query",
            "description": "Filter by label IDs.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 15
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of recurring campaigns.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaigns": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "Total number of recurring campaigns."
                        },
                        "per_page": {
                          "type": "integer",
                          "description": "Number of results per page."
                        },
                        "current_page": {
                          "type": "integer",
                          "description": "Current page number."
                        },
                        "last_page": {
                          "type": "integer",
                          "description": "Last page number."
                        },
                        "next_page_url": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "URL for the next page, or null if on the last page."
                        },
                        "prev_page_url": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "URL for the previous page, or null if on the first page."
                        },
                        "from": {
                          "type": "integer",
                          "description": "Starting record index on this page."
                        },
                        "to": {
                          "type": "integer",
                          "description": "Ending record index on this page."
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/RecurringCampaign"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "campaigns": {
                    "total": 3,
                    "per_page": 15,
                    "current_page": 1,
                    "last_page": 1,
                    "next_page_url": null,
                    "prev_page_url": null,
                    "from": 1,
                    "to": 3,
                    "data": [
                      {
                        "id": 1,
                        "title": "Weekly Newsletter",
                        "status": "active",
                        "settings": {
                          "scheduling_settings": {
                            "type": "weekly",
                            "day": "mon",
                            "time": "09.00",
                            "send_automatically": "yes"
                          },
                          "sending_conditions": [],
                          "subscribers_settings": {}
                        },
                        "scheduled_at": "2024-04-01 09:00:00",
                        "created_at": "2024-03-01 10:00:00",
                        "emails_count": 12,
                        "has_draft": false,
                        "labels": [
                          {
                            "id": 1,
                            "slug": "newsletter",
                            "title": "Newsletter",
                            "color": "#409EFF"
                          }
                        ]
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "RecurringCampaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the recurring campaign."
          },
          "title": {
            "type": "string",
            "description": "Campaign title."
          },
          "slug": {
            "type": "string",
            "description": "URL-friendly slug derived from the title."
          },
          "status": {
            "type": "string",
            "description": "Campaign status.",
            "enum": [
              "draft",
              "active"
            ]
          },
          "type": {
            "type": "string",
            "description": "Record type (always `recurring_campaign`).",
            "enum": [
              "recurring_campaign"
            ]
          },
          "template_id": {
            "type": "integer",
            "nullable": true,
            "description": "Associated email template ID."
          },
          "email_subject": {
            "type": "string",
            "description": "Email subject line."
          },
          "email_pre_header": {
            "type": "string",
            "description": "Email pre-header text."
          },
          "email_body": {
            "type": "string",
            "description": "Email body content (HTML)."
          },
          "recipients_count": {
            "type": "integer",
            "description": "Number of recipients."
          },
          "utm_status": {
            "type": "integer",
            "description": "Whether UTM tracking is enabled (1 = enabled, 0 = disabled)."
          },
          "utm_source": {
            "type": "string",
            "description": "UTM source parameter."
          },
          "utm_medium": {
            "type": "string",
            "description": "UTM medium parameter."
          },
          "utm_campaign": {
            "type": "string",
            "description": "UTM campaign parameter."
          },
          "utm_term": {
            "type": "string",
            "description": "UTM term parameter."
          },
          "utm_content": {
            "type": "string",
            "description": "UTM content parameter."
          },
          "design_template": {
            "type": "string",
            "description": "Design template for the campaign (e.g., `simple`, `visual_builder`)."
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Next scheduled send date/time."
          },
          "settings": {
            "type": "object",
            "description": "Campaign settings including scheduling, sending conditions, subscriber targeting, and mailer configuration.",
            "properties": {
              "mailer_settings": {
                "type": "object",
                "properties": {
                  "from_name": {
                    "type": "string",
                    "description": "Sender name."
                  },
                  "from_email": {
                    "type": "string",
                    "description": "Sender email address."
                  },
                  "reply_to_name": {
                    "type": "string",
                    "description": "Reply-to name."
                  },
                  "reply_to_email": {
                    "type": "string",
                    "description": "Reply-to email address."
                  },
                  "is_custom": {
                    "type": "string",
                    "description": "Whether custom mailer settings are enabled.",
                    "enum": [
                      "yes",
                      "no"
                    ]
                  }
                }
              },
              "scheduling_settings": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Schedule type.",
                    "enum": [
                      "daily",
                      "weekly",
                      "monthly",
                      "yearly"
                    ]
                  },
                  "day": {
                    "type": "string",
                    "description": "Day for weekly schedules (e.g., `mon`, `tue`)."
                  },
                  "time": {
                    "type": "string",
                    "description": "Time of day (e.g., `09.00`)."
                  },
                  "send_automatically": {
                    "type": "string",
                    "description": "Whether to send automatically or create drafts for review.",
                    "enum": [
                      "yes",
                      "no"
                    ]
                  }
                }
              },
              "sending_conditions": {
                "type": "array",
                "description": "Conditions that must be met before sending.",
                "items": {
                  "type": "object"
                }
              },
              "subscribers_settings": {
                "type": "object",
                "description": "Subscriber targeting settings.",
                "properties": {
                  "subscribers": {
                    "type": "array",
                    "description": "Included subscriber segments.",
                    "items": {
                      "type": "object"
                    }
                  },
                  "excludedSubscribers": {
                    "type": "array",
                    "description": "Excluded subscriber segments.",
                    "items": {
                      "type": "object"
                    }
                  },
                  "sending_filter": {
                    "type": "string",
                    "description": "Filter type for subscriber selection."
                  },
                  "dynamic_segment": {
                    "type": "object",
                    "description": "Dynamic segment configuration."
                  },
                  "advanced_filters": {
                    "type": "array",
                    "description": "Advanced filter conditions.",
                    "items": {
                      "type": "array"
                    }
                  }
                }
              },
              "template_config": {
                "type": "object",
                "description": "Template configuration."
              }
            }
          },
          "created_by": {
            "type": "integer",
            "description": "WordPress user ID of the creator."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the campaign was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the campaign was last updated."
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}