{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/webhooks/{id}": {
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "DELETE Delete Webhook",
        "description": "Permanently delete a webhook by ID. This removes the webhook and its configuration. The webhook URL will no longer accept incoming data.",
        "tags": [
          "Webhooks"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The webhook ID to delete.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "webhooks": {
                      "type": "array",
                      "description": "Updated list of all remaining webhooks.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Unique identifier for the webhook."
                          },
                          "object_type": {
                            "type": "string",
                            "description": "Type discriminator. `webhook` for standard webhooks, `webhook_{provider}` for SMS webhooks."
                          },
                          "key": {
                            "type": "string",
                            "description": "UUID key used in the webhook URL."
                          },
                          "value": {
                            "type": "object",
                            "description": "Webhook configuration data.",
                            "properties": {
                              "name": {
                                "type": "string",
                                "description": "Human-readable webhook name."
                              },
                              "status": {
                                "type": "string",
                                "description": "Default subscription status for contacts created via this webhook.",
                                "enum": [
                                  "subscribed",
                                  "pending",
                                  "unsubscribed"
                                ]
                              },
                              "lists": {
                                "type": "array",
                                "items": {
                                  "type": "integer"
                                },
                                "description": "List IDs to assign to incoming contacts."
                              },
                              "tags": {
                                "type": "array",
                                "items": {
                                  "type": "integer"
                                },
                                "description": "Tag IDs to assign to incoming contacts."
                              },
                              "companies": {
                                "type": "array",
                                "items": {
                                  "type": "integer"
                                },
                                "description": "Company IDs to assign to incoming contacts."
                              },
                              "url": {
                                "type": "string",
                                "description": "The webhook endpoint URL."
                              }
                            }
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Timestamp when the webhook was created."
                          },
                          "updated_at": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Timestamp when the webhook was last updated."
                          }
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "description": "Success message."
                    }
                  }
                },
                "example": {
                  "webhooks": [],
                  "message": "Successfully deleted the webhook"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}