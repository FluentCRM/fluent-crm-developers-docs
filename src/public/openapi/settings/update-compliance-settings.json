{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/setting/compliance": {
      "post": {
        "operationId": "updateComplianceSettings",
        "summary": "POST Update Compliance Settings",
        "description": "Update GDPR and data compliance settings. Only accepts known compliance setting keys. Values must be `yes`, `no`, or `anonymous`; invalid values are cleared to empty strings.",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Compliance setting key-value pairs. Only known keys from the existing compliance settings will be accepted.",
                "additionalProperties": {
                  "type": "string",
                  "enum": [
                    "yes",
                    "no",
                    "anonymous"
                  ]
                }
              },
              "example": {
                "delete_contact_on_user": "no",
                "anonymize_ip": "yes",
                "anonymize_on_unsubscribe": "anonymous"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compliance settings updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "settings": {
                      "type": "object",
                      "description": "The updated compliance settings.",
                      "additionalProperties": {
                        "type": "string"
                      }
                    }
                  }
                },
                "example": {
                  "message": "Settings has been successfully updated",
                  "settings": {
                    "delete_contact_on_user": "no",
                    "anonymize_ip": "yes",
                    "anonymize_on_unsubscribe": "anonymous"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}