{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/custom-fields/contacts/update_group_name": {
      "put": {
        "operationId": "updateCustomFieldGroupName",
        "summary": "PUT Update Custom Field Group Name",
        "description": "Rename a custom field group. All custom fields currently assigned to the old group name will be updated to use the new group name. Both names are sanitized server-side.",
        "tags": [
          "Custom Fields"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "old_name",
                  "new_name"
                ],
                "properties": {
                  "old_name": {
                    "type": "string",
                    "description": "The current group name to rename."
                  },
                  "new_name": {
                    "type": "string",
                    "description": "The new group name."
                  }
                }
              },
              "example": {
                "old_name": "Custom Profile Data",
                "new_name": "Contact Details"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Group name updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fields": {
                      "type": "array",
                      "description": "All custom field definitions with the updated group name applied.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string",
                            "description": "Human-readable field label."
                          },
                          "slug": {
                            "type": "string",
                            "description": "Unique field identifier/slug. Auto-generated from label if not provided."
                          },
                          "type": {
                            "type": "string",
                            "description": "Field type.",
                            "enum": [
                              "text",
                              "textarea",
                              "number",
                              "select-one",
                              "select-multi",
                              "radio",
                              "checkbox",
                              "date",
                              "date_time"
                            ]
                          },
                          "group": {
                            "type": "string",
                            "description": "Field group name for organizing fields into sections."
                          },
                          "options": {
                            "type": "array",
                            "description": "Available options for select, radio, and checkbox field types.",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "description": "Success message."
                    }
                  }
                },
                "example": {
                  "fields": [
                    {
                      "label": "Company Name",
                      "slug": "company_name",
                      "type": "text",
                      "group": "Contact Details",
                      "options": []
                    },
                    {
                      "label": "Subscription Plan",
                      "slug": "subscription_plan",
                      "type": "select-one",
                      "group": "Contact Details",
                      "options": [
                        "Free",
                        "Pro",
                        "Enterprise"
                      ]
                    }
                  ],
                  "message": "Group name updated successfully!"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}