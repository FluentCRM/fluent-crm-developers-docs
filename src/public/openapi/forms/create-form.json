{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/forms": {
      "post": {
        "operationId": "createForm",
        "summary": "POST Create Form",
        "description": "Create a new Fluent Form with FluentCRM integration pre-configured. The form is created from a template and automatically gets a FluentCRM integration feed with the specified tags and list. Requires Fluent Forms to be installed.",
        "tags": [
          "Forms"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "template_id",
                  "title",
                  "selected_tags",
                  "selected_list"
                ],
                "properties": {
                  "template_id": {
                    "type": "string",
                    "description": "Template ID to create the form from (e.g., `inline_subscribe`, `simple_optin`, `with_name_subscribe`)."
                  },
                  "title": {
                    "type": "string",
                    "description": "Form title. Must be unique across all Fluent Forms."
                  },
                  "selected_tags": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "FluentCRM tag IDs to assign to form submissions."
                  },
                  "selected_list": {
                    "type": "integer",
                    "description": "FluentCRM list ID to assign to form submissions."
                  },
                  "double_optin": {
                    "type": "boolean",
                    "description": "Whether to enable double opt-in for form submissions."
                  }
                }
              },
              "example": {
                "template_id": "inline_subscribe",
                "title": "Newsletter Signup",
                "selected_tags": [
                  1,
                  3
                ],
                "selected_list": 2,
                "double_optin": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Form created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message."
                    },
                    "created_form": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Created form ID."
                        },
                        "shortcode": {
                          "type": "string",
                          "description": "WordPress shortcode to embed the form."
                        },
                        "feed_url": {
                          "type": "string",
                          "description": "URL to the FluentCRM integration feed settings."
                        },
                        "edit_url": {
                          "type": "string",
                          "description": "URL to edit the form."
                        },
                        "preview_url": {
                          "type": "string",
                          "description": "URL to preview the form."
                        }
                      }
                    }
                  }
                },
                "example": {
                  "message": "Form has been created",
                  "created_form": {
                    "id": 12,
                    "shortcode": "[fluentform id=\"12\"]",
                    "feed_url": "https://example.com/wp-admin/admin.php?page=fluent_forms&form_id=12&route=settings",
                    "edit_url": "https://example.com/wp-admin/admin.php?page=fluent_forms&route=editor&form_id=12",
                    "preview_url": "https://example.com/?fluent_forms_pages=1&design_mode=1&preview_id=12"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error (e.g., missing required fields, duplicate title).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "message": "Unprocessable Entity",
                  "errors": {
                    "title": [
                      "The title has already been taken."
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}