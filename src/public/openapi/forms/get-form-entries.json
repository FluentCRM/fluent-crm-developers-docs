{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/forms/{id}/entries": {
      "get": {
        "operationId": "getFormEntries",
        "summary": "GET Form Entries",
        "description": "Retrieve a paginated list of form submission entries for a specific Fluent Form. Includes submission data, browser info, device info, and a link to view the entry in the Fluent Forms admin. Requires Fluent Forms to be installed and appropriate entry viewer permissions.",
        "tags": [
          "Forms"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Form ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "Number of entries per page.",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Search entries by response content or status.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of form entries.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/FormEntry"
                          }
                        },
                        "page": {
                          "type": "integer",
                          "description": "Current page number."
                        },
                        "per_page": {
                          "type": "integer",
                          "description": "Items per page."
                        },
                        "total": {
                          "type": "integer",
                          "description": "Total number of entries."
                        },
                        "last_page": {
                          "type": "integer",
                          "description": "Last page number."
                        }
                      }
                    },
                    "form": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Form ID."
                        },
                        "title": {
                          "type": "string",
                          "description": "Form title."
                        }
                      }
                    }
                  }
                },
                "example": {
                  "entries": {
                    "data": [
                      {
                        "id": 101,
                        "serial_number": 1,
                        "status": "read",
                        "created_at": "2024-03-01 14:30:00",
                        "response": {
                          "email": "john@example.com",
                          "names": {
                            "first_name": "John",
                            "last_name": "Doe"
                          }
                        },
                        "user_id": 5,
                        "browser": "Chrome",
                        "device": "Desktop",
                        "ip": "192.168.1.1",
                        "entry_url": "https://example.com/wp-admin/admin.php?page=fluent_forms&form_id=5&route=entries#/entries/101"
                      }
                    ],
                    "page": 1,
                    "per_page": 10,
                    "total": 25,
                    "last_page": 3
                  },
                  "form": {
                    "id": 5,
                    "title": "Newsletter Signup"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Fluent Forms not installed, form not found, or insufficient permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "entries": {
                      "type": "array",
                      "items": {}
                    }
                  }
                },
                "example": {
                  "message": "Fluent Forms is not installed",
                  "entries": []
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "FormEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Entry ID."
          },
          "serial_number": {
            "type": "integer",
            "description": "Sequential entry number within the form."
          },
          "status": {
            "type": "string",
            "description": "Entry status (e.g., `read`, `unread`)."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Submission timestamp."
          },
          "response": {
            "type": "object",
            "additionalProperties": true,
            "description": "Form submission data as key-value pairs."
          },
          "user_id": {
            "type": [
              "integer",
              "null"
            ],
            "description": "WordPress user ID of the submitter, if logged in."
          },
          "browser": {
            "type": [
              "string",
              "null"
            ],
            "description": "Browser used for submission."
          },
          "device": {
            "type": [
              "string",
              "null"
            ],
            "description": "Device type used for submission."
          },
          "ip": {
            "type": [
              "string",
              "null"
            ],
            "description": "IP address of the submitter."
          },
          "entry_url": {
            "type": "string",
            "description": "Admin URL to view the full entry."
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}