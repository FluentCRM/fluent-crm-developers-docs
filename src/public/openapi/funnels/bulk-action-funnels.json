{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/funnels/do-bulk-action": {
      "post": {
        "operationId": "bulkActionFunnels",
        "summary": "POST Bulk Action Funnels",
        "description": "Perform a bulk action on multiple funnels. Supported actions: `change_funnel_status` (change status of selected funnels), `delete_funnels` (permanently delete selected funnels and all associated data), and `apply_labels` (attach labels to selected funnels).",
        "tags": [
          "Funnels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action_name",
                  "funnel_ids"
                ],
                "properties": {
                  "action_name": {
                    "type": "string",
                    "enum": [
                      "change_funnel_status",
                      "delete_funnels",
                      "apply_labels"
                    ],
                    "description": "The bulk action to perform."
                  },
                  "funnel_ids": {
                    "type": "array",
                    "description": "Array of funnel IDs to act on.",
                    "items": {
                      "type": "integer"
                    }
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "draft",
                      "published"
                    ],
                    "description": "New status to set. Required when `action_name` is `change_funnel_status`."
                  },
                  "labels": {
                    "type": "array",
                    "description": "Array of label IDs to apply. Required when `action_name` is `apply_labels`.",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              },
              "examples": {
                "change_status": {
                  "summary": "Change funnel status",
                  "value": {
                    "action_name": "change_funnel_status",
                    "funnel_ids": [
                      1,
                      2,
                      3
                    ],
                    "status": "published"
                  }
                },
                "delete": {
                  "summary": "Delete funnels",
                  "value": {
                    "action_name": "delete_funnels",
                    "funnel_ids": [
                      4,
                      5
                    ]
                  }
                },
                "apply_labels": {
                  "summary": "Apply labels to funnels",
                  "value": {
                    "action_name": "apply_labels",
                    "funnel_ids": [
                      1,
                      2
                    ],
                    "labels": [
                      1,
                      3
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk action completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "examples": {
                  "status_changed": {
                    "value": {
                      "message": "Status has been changed for the selected funnels"
                    }
                  },
                  "deleted": {
                    "value": {
                      "message": "Selected Funnels have been deleted permanently"
                    }
                  },
                  "labels_applied": {
                    "value": {
                      "message": "Labels has been applied successfully"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Invalid action or missing required parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Please provide funnel IDs"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}