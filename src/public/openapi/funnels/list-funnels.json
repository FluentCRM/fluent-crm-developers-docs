{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/funnels": {
      "get": {
        "operationId": "listFunnels",
        "summary": "GET List Funnels",
        "description": "Retrieve a paginated list of automation funnels. Supports sorting, searching by title, and filtering by label IDs. Optionally includes trigger definitions.",
        "tags": [
          "Funnels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "sort_by",
            "in": "query",
            "description": "Column to sort by.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "id"
            }
          },
          {
            "name": "sort_type",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "DESC",
              "enum": [
                "ASC",
                "DESC"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search funnels by title (partial match).",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "labels[]",
            "in": "query",
            "description": "Filter funnels by label IDs.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "with[]",
            "in": "query",
            "description": "Include additional related data. Supported values: `triggers`.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "triggers"
                ]
              }
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of funnels per page.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 15
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of funnels.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "funnels": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "Total number of funnels matching the query."
                        },
                        "per_page": {
                          "type": "integer",
                          "description": "Number of funnels per page."
                        },
                        "current_page": {
                          "type": "integer",
                          "description": "Current page number."
                        },
                        "last_page": {
                          "type": "integer",
                          "description": "Last page number."
                        },
                        "next_page_url": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "URL for the next page, or null if on the last page."
                        },
                        "prev_page_url": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "URL for the previous page, or null if on the first page."
                        },
                        "from": {
                          "type": "integer",
                          "description": "Starting record index on this page."
                        },
                        "to": {
                          "type": "integer",
                          "description": "Ending record index on this page."
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Funnel"
                          }
                        }
                      }
                    },
                    "triggers": {
                      "type": "object",
                      "description": "Map of trigger definitions keyed by trigger name. Only included when `with[]` contains `triggers`.",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/Trigger"
                      }
                    }
                  }
                },
                "example": {
                  "funnels": {
                    "total": 5,
                    "per_page": 15,
                    "current_page": 1,
                    "last_page": 1,
                    "next_page_url": null,
                    "prev_page_url": null,
                    "from": 1,
                    "to": 5,
                    "data": [
                      {
                        "id": 1,
                        "title": "Welcome Email Sequence",
                        "trigger_name": "fluent_crm/contact_created",
                        "status": "published",
                        "conditions": [],
                        "settings": {},
                        "created_by": 1,
                        "created_at": "2024-01-15 10:30:00",
                        "updated_at": "2024-03-01 14:30:00",
                        "subscribers_count": 120,
                        "description": "Sends welcome emails to new contacts",
                        "labels": [
                          {
                            "id": 1,
                            "title": "Onboarding",
                            "slug": "onboarding",
                            "color": "#4CAF50"
                          }
                        ]
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "Funnel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the funnel."
          },
          "title": {
            "type": "string",
            "description": "Funnel title."
          },
          "trigger_name": {
            "type": "string",
            "description": "The trigger event name that starts this funnel."
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "published"
            ],
            "description": "Funnel status."
          },
          "conditions": {
            "type": "array",
            "description": "Funnel-level conditions.",
            "items": {
              "type": "object"
            }
          },
          "settings": {
            "type": "object",
            "description": "Funnel settings."
          },
          "created_by": {
            "type": "integer",
            "description": "WordPress user ID of the creator."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the funnel was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the funnel was last updated."
          },
          "subscribers_count": {
            "type": "integer",
            "description": "Number of subscribers in this funnel."
          },
          "description": {
            "type": [
              "string",
              "null"
            ],
            "description": "Funnel description stored as meta."
          },
          "labels": {
            "type": "array",
            "description": "Labels assigned to the funnel.",
            "items": {
              "$ref": "#/components/schemas/FunnelLabel"
            }
          }
        }
      },
      "FunnelLabel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Label ID."
          },
          "title": {
            "type": "string",
            "description": "Label title."
          },
          "slug": {
            "type": "string",
            "description": "Label slug."
          },
          "color": {
            "type": [
              "string",
              "null"
            ],
            "description": "Label hex color code."
          }
        }
      },
      "Trigger": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "Human-readable trigger label."
          },
          "category": {
            "type": "string",
            "description": "Trigger category."
          },
          "description": {
            "type": "string",
            "description": "Trigger description."
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}