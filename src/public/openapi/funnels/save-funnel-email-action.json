{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/funnels/{id}/sequences/save-email-action": {
      "post": {
        "operationId": "saveFunnelEmailAction",
        "summary": "POST Save Funnel Email Action",
        "description": "Create or update a funnel email campaign associated with a specific funnel. If a campaign ID is provided and matches the funnel, it updates the existing campaign; otherwise, it creates a new one. Also handles visual builder design data.",
        "tags": [
          "Funnels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The funnel ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action_data"
                ],
                "properties": {
                  "action_data": {
                    "type": [
                      "object",
                      "string"
                    ],
                    "description": "Email action data object or JSON string containing campaign details.",
                    "properties": {
                      "campaign": {
                        "type": "object",
                        "description": "Campaign data.",
                        "properties": {
                          "id": {
                            "type": [
                              "integer",
                              "null"
                            ],
                            "description": "Existing campaign ID for updates."
                          },
                          "email_subject": {
                            "type": "string",
                            "description": "Email subject line."
                          },
                          "email_pre_header": {
                            "type": "string",
                            "description": "Email pre-header text."
                          },
                          "email_body": {
                            "type": "string",
                            "description": "Email HTML body content."
                          },
                          "design_template": {
                            "type": "string",
                            "description": "Design template type (e.g., `simple`, `visual_builder`)."
                          },
                          "settings": {
                            "type": "object",
                            "description": "Campaign settings."
                          },
                          "_visual_builder_design": {
                            "type": "object",
                            "description": "Visual builder design data. Only used when `design_template` is `visual_builder`."
                          }
                        }
                      },
                      "mailer_settings": {
                        "type": "object",
                        "description": "Email mailer configuration."
                      }
                    }
                  }
                }
              },
              "example": {
                "action_data": {
                  "campaign": {
                    "email_subject": "Welcome to Our Service!",
                    "email_body": "<p>Hello {{contact.first_name}},</p><p>Welcome!</p>",
                    "design_template": "simple",
                    "settings": {}
                  },
                  "mailer_settings": {}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email action saved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "created",
                        "updated"
                      ],
                      "description": "Whether the campaign was created or updated."
                    },
                    "reference_campaign": {
                      "type": "integer",
                      "description": "The funnel campaign ID."
                    },
                    "campaign": {
                      "type": "object",
                      "description": "The saved campaign data."
                    }
                  }
                },
                "example": {
                  "type": "created",
                  "reference_campaign": 10,
                  "campaign": {
                    "email_subject": "Welcome to Our Service!",
                    "email_body": "<p>Hello {{contact.first_name}},</p><p>Welcome!</p>"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}