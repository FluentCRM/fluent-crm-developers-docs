{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/funnels/import": {
      "post": {
        "operationId": "importFunnel",
        "summary": "POST Import Funnel",
        "description": "Import an automation funnel from exported data. Creates a new funnel in `draft` status with all sequences and labels from the provided data.",
        "tags": [
          "Funnels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "funnel",
                  "sequences"
                ],
                "properties": {
                  "funnel": {
                    "type": "object",
                    "description": "Funnel data including title, trigger_name, conditions, settings, and labels.",
                    "properties": {
                      "title": {
                        "type": "string",
                        "description": "Funnel title."
                      },
                      "trigger_name": {
                        "type": "string",
                        "description": "Trigger event name."
                      },
                      "conditions": {
                        "type": "array",
                        "description": "Funnel conditions.",
                        "items": {
                          "type": "object"
                        }
                      },
                      "settings": {
                        "type": "object",
                        "description": "Funnel settings."
                      },
                      "labels": {
                        "type": "array",
                        "description": "Labels to import or match.",
                        "items": {
                          "type": "object",
                          "properties": {
                            "slug": {
                              "type": "string"
                            },
                            "title": {
                              "type": "string"
                            },
                            "color": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  },
                  "sequences": {
                    "type": [
                      "array",
                      "string"
                    ],
                    "description": "Array of funnel sequence objects, or a JSON string that will be parsed.",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              },
              "example": {
                "funnel": {
                  "title": "Imported Funnel",
                  "trigger_name": "fluent_crm/contact_created",
                  "conditions": [],
                  "settings": {}
                },
                "sequences": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Funnel imported successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "funnel": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Unique identifier for the funnel."
                        },
                        "title": {
                          "type": "string",
                          "description": "Funnel title."
                        },
                        "trigger_name": {
                          "type": "string",
                          "description": "The trigger event name that starts this funnel."
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "draft",
                            "published"
                          ],
                          "description": "Funnel status."
                        },
                        "conditions": {
                          "type": "array",
                          "description": "Funnel-level conditions.",
                          "items": {
                            "type": "object"
                          }
                        },
                        "settings": {
                          "type": "object",
                          "description": "Funnel settings."
                        },
                        "created_by": {
                          "type": "integer",
                          "description": "WordPress user ID of the creator."
                        },
                        "created_at": {
                          "type": "string",
                          "format": "date-time",
                          "description": "Timestamp when the funnel was created."
                        },
                        "updated_at": {
                          "type": "string",
                          "format": "date-time",
                          "description": "Timestamp when the funnel was last updated."
                        },
                        "subscribers_count": {
                          "type": "integer",
                          "description": "Number of subscribers in this funnel."
                        },
                        "description": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Funnel description stored as meta."
                        },
                        "labels": {
                          "type": "array",
                          "description": "Labels assigned to the funnel.",
                          "items": {
                            "$ref": "#/components/schemas/FunnelLabel"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "message": "Funnel has been successfully imported",
                  "funnel": {
                    "id": 7,
                    "title": "Imported Funnel",
                    "trigger_name": "fluent_crm/contact_created",
                    "status": "draft",
                    "created_by": 1,
                    "created_at": "2024-03-01 10:00:00",
                    "updated_at": "2024-03-01 10:00:00"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}