{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/funnels/{id}/subscribers/{subscriber_id}/status": {
      "put": {
        "operationId": "updateFunnelSubscriptionStatus",
        "summary": "PUT Update Funnel Subscription Status",
        "description": "Update the status of a subscriber within a specific funnel. Cannot change status if the subscriber is already in `completed` state. Allowed target statuses are `active`, `completed`, and `cancelled`.",
        "tags": [
          "Funnels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The funnel ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "subscriber_id",
            "in": "path",
            "description": "The subscriber/contact ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "completed",
                      "cancelled"
                    ],
                    "description": "The new subscription status."
                  }
                }
              },
              "example": {
                "status": "cancelled"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Status has been updated to cancelled"
                }
              }
            }
          },
          "422": {
            "description": "Invalid status or subscriber already completed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "examples": {
                  "invalid_status": {
                    "value": {
                      "message": "Invalid subscription status"
                    }
                  },
                  "already_completed": {
                    "value": {
                      "message": "The status already completed state"
                    }
                  },
                  "not_found": {
                    "value": {
                      "message": "No Corresponding report found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}