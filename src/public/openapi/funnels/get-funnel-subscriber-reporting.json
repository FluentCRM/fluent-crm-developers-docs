{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM \u2014 a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/funnels/{id}/subscribers/{contact_id}": {
      "get": {
        "operationId": "getFunnelSubscriberReporting",
        "summary": "GET Get Funnel Subscriber Reporting",
        "description": "Retrieve detailed reporting for a specific subscriber within a funnel. Returns the subscriber's funnel progress, metrics, and all funnel sequences.",
        "tags": [
          "Funnels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The funnel ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "contact_id",
            "in": "path",
            "description": "The subscriber/contact ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriber reporting data.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "funnel_subscriber": {
                      "type": [
                        "object",
                        "null"
                      ],
                      "description": "The funnel subscriber record with progress details, or null if the subscriber is not in this funnel.",
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "funnel_id": {
                          "type": "integer"
                        },
                        "subscriber_id": {
                          "type": "integer"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "active",
                            "completed",
                            "cancelled",
                            "pending",
                            "waiting"
                          ]
                        },
                        "last_sequence_id": {
                          "type": [
                            "integer",
                            "null"
                          ]
                        },
                        "next_sequence_id": {
                          "type": [
                            "integer",
                            "null"
                          ]
                        },
                        "next_execution_time": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "date-time"
                        },
                        "created_at": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "updated_at": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "last_sequence": {
                          "type": [
                            "object",
                            "null"
                          ]
                        },
                        "next_sequence_item": {
                          "type": [
                            "object",
                            "null"
                          ]
                        },
                        "metrics": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "funnel_id": {
                                "type": "integer"
                              },
                              "sequence_id": {
                                "type": "integer"
                              },
                              "subscriber_id": {
                                "type": "integer"
                              },
                              "benchmark_value": {
                                "type": "number"
                              },
                              "benchmark_currency": {
                                "type": "string"
                              },
                              "status": {
                                "type": "string"
                              },
                              "notes": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "created_at": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "updated_at": {
                                "type": "string",
                                "format": "date-time"
                              }
                            }
                          }
                        }
                      }
                    },
                    "sequences": {
                      "type": "array",
                      "description": "All sequences in this funnel ordered by position.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Sequence ID."
                          },
                          "funnel_id": {
                            "type": "integer",
                            "description": "Associated funnel ID."
                          },
                          "action_name": {
                            "type": "string",
                            "description": "Action identifier."
                          },
                          "title": {
                            "type": "string",
                            "description": "Sequence title."
                          },
                          "type": {
                            "type": "string",
                            "enum": [
                              "action",
                              "conditional",
                              "benchmark"
                            ],
                            "description": "Sequence type."
                          },
                          "settings": {
                            "type": "object",
                            "description": "Action-specific settings."
                          },
                          "conditions": {
                            "type": "array",
                            "description": "Step-level conditions.",
                            "items": {
                              "type": "object"
                            }
                          },
                          "sequence": {
                            "type": "integer",
                            "description": "Order position."
                          },
                          "delay": {
                            "type": "integer",
                            "description": "Delay in seconds."
                          },
                          "c_delay": {
                            "type": "integer",
                            "description": "Cumulative delay in seconds."
                          },
                          "status": {
                            "type": "string",
                            "description": "Sequence status."
                          },
                          "parent_id": {
                            "type": "integer",
                            "description": "Parent sequence ID (0 for root)."
                          },
                          "condition_type": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Branch type for conditional children."
                          },
                          "children": {
                            "type": "object",
                            "description": "Child sequences for conditional blocks.",
                            "properties": {
                              "yes": {
                                "type": "array",
                                "items": {
                                  "$ref": "#/components/schemas/FunnelSequence"
                                }
                              },
                              "no": {
                                "type": "array",
                                "items": {
                                  "$ref": "#/components/schemas/FunnelSequence"
                                }
                              }
                            }
                          },
                          "created_by": {
                            "type": "integer"
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "updated_at": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "funnel_subscriber": {
                    "id": 1,
                    "funnel_id": 1,
                    "subscriber_id": 42,
                    "status": "active",
                    "last_sequence_id": 3,
                    "next_sequence_id": 4,
                    "next_execution_time": "2024-03-02 10:00:00",
                    "created_at": "2024-03-01 10:00:00",
                    "updated_at": "2024-03-01 14:30:00",
                    "metrics": []
                  },
                  "sequences": []
                }
              }
            }
          },
          "404": {
            "description": "Funnel or subscriber not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}