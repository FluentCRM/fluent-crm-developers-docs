{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/campaigns/{id}/emails": {
      "get": {
        "operationId": "getCampaignEmails",
        "summary": "GET Get Campaign Emails",
        "description": "Retrieve a paginated list of emails sent for a specific campaign. Supports filtering by engagement type (click, view, unopened, failed) and searching by subscriber details. Optionally includes the campaign data with tracking status.",
        "tags": [
          "Campaigns"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The campaign ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "filter_type",
            "in": "query",
            "description": "Filter emails by engagement type.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "click",
                "view",
                "unopened",
                "failed"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search by subscriber name or email.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "with_campaign",
            "in": "query",
            "description": "Set to include the campaign object (with tracking status) in the response.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 15
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign emails retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "emails": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "campaign_id": {
                                "type": "integer"
                              },
                              "subscriber_id": {
                                "type": "integer"
                              },
                              "email_subject": {
                                "type": "string"
                              },
                              "email_pre_header": {
                                "type": "string"
                              },
                              "status": {
                                "type": "string",
                                "enum": [
                                  "draft",
                                  "pending",
                                  "processing",
                                  "scheduled",
                                  "sent",
                                  "failed",
                                  "bounced",
                                  "paused"
                                ]
                              },
                              "is_open": {
                                "type": "integer",
                                "description": "Number of times the email was opened."
                              },
                              "click_counter": {
                                "type": "integer",
                                "nullable": true,
                                "description": "Number of link clicks."
                              },
                              "scheduled_at": {
                                "type": "string",
                                "format": "date-time",
                                "nullable": true
                              },
                              "created_at": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "updated_at": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "subscriber": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "integer"
                                  },
                                  "email": {
                                    "type": "string"
                                  },
                                  "first_name": {
                                    "type": "string"
                                  },
                                  "last_name": {
                                    "type": "string"
                                  },
                                  "status": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "failed_counts": {
                      "type": "integer",
                      "description": "Total number of failed emails for this campaign."
                    },
                    "campaign": {
                      "type": "object",
                      "nullable": true,
                      "description": "Included only when `with_campaign` is set.",
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "title": {
                          "type": "string"
                        },
                        "open_tracking_status": {
                          "type": "string"
                        },
                        "click_tracking_status": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "emails": {
                    "total": 1200,
                    "per_page": 15,
                    "current_page": 1,
                    "last_page": 80,
                    "data": [
                      {
                        "id": 456,
                        "campaign_id": 12,
                        "subscriber_id": 42,
                        "email_subject": "Welcome aboard!",
                        "email_pre_header": "We are glad to have you",
                        "status": "sent",
                        "is_open": 3,
                        "click_counter": 2,
                        "scheduled_at": "2024-03-01 10:00:00",
                        "created_at": "2024-03-01 10:00:00",
                        "updated_at": "2024-03-01 12:30:00",
                        "subscriber": {
                          "id": 42,
                          "email": "john@example.com",
                          "first_name": "John",
                          "last_name": "Doe",
                          "status": "subscribed"
                        }
                      }
                    ]
                  },
                  "failed_counts": 5
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}