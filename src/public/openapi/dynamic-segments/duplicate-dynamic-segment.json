{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/dynamic-segments/duplicate/{id}": {
      "post": {
        "operationId": "duplicateDynamicSegment",
        "summary": "POST Duplicate Dynamic Segment",
        "description": "Create a copy of an existing custom dynamic segment. The duplicated segment will have `[Duplicate]` prepended to its title. Requires FluentCampaign Pro.",
        "tags": [
          "Dynamic Segments"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The ID of the custom segment to duplicate.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Segment duplicated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message."
                    },
                    "segment_id": {
                      "type": "integer",
                      "description": "ID of the newly created duplicate segment."
                    }
                  }
                },
                "example": {
                  "message": "Segment successfully duplicated",
                  "segment_id": 18
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}