{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/dynamic-segments/stats": {
      "get": {
        "operationId": "getDynamicSegmentStats",
        "summary": "GET Get Dynamic Segment Stats",
        "description": "Retrieve contact count statistics for all registered dynamic segments. Returns a map of segment keys to their subscriber counts. Requires FluentCampaign Pro.",
        "tags": [
          "Dynamic Segments"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Segment statistics keyed by `{slug}_{id}`.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stats": {
                      "type": [
                        "object",
                        "null"
                      ],
                      "description": "Map of segment keys (`{slug}_{id}`) to subscriber counts. Returns `null` if no segments have data.",
                      "additionalProperties": {
                        "type": "integer"
                      }
                    }
                  }
                },
                "example": {
                  "stats": {
                    "wordpress_users_0": 150,
                    "custom_segment_12": 85,
                    "custom_segment_15": 42
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}