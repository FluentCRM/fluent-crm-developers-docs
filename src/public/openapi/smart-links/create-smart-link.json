{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/smart-links": {
      "post": {
        "operationId": "createSmartLink",
        "summary": "POST Create Smart Link",
        "description": "Create a new smart link with a target URL and optional actions (add/remove tags, add/remove lists, auto-login). A unique short slug is generated automatically. Requires FluentCampaign Pro.",
        "tags": [
          "Smart Links"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "link"
                ],
                "properties": {
                  "link": {
                    "$ref": "#/components/schemas/SmartLinkInput"
                  }
                }
              },
              "example": {
                "link": {
                  "title": "Upgrade Interest Link",
                  "target_url": "https://example.com/upgrade",
                  "actions": {
                    "tags": [
                      1,
                      3
                    ],
                    "lists": [
                      2
                    ]
                  },
                  "detach_actions": {
                    "tags": [
                      5
                    ],
                    "lists": []
                  },
                  "auto_login": "no",
                  "notes": "Track users interested in upgrading"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Smart link created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "link": {
                      "type": "object",
                      "description": "The created smart link object.",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Unique identifier."
                        },
                        "title": {
                          "type": "string",
                          "description": "Display title."
                        },
                        "short": {
                          "type": "string",
                          "description": "Generated short slug."
                        },
                        "target_url": {
                          "type": "string",
                          "description": "Destination URL."
                        },
                        "actions": {
                          "type": "object",
                          "description": "Actions configuration."
                        },
                        "notes": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Optional notes."
                        },
                        "created_by": {
                          "type": "integer",
                          "description": "Creator's WordPress user ID."
                        },
                        "created_at": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "updated_at": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "short_url": {
                          "type": "string",
                          "description": "Full trackable URL."
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "description": "Success message."
                    }
                  }
                },
                "example": {
                  "link": {
                    "id": 4,
                    "title": "Upgrade Interest Link",
                    "short": "x7y8z9",
                    "target_url": "https://example.com/upgrade",
                    "actions": {
                      "tags": [
                        1,
                        3
                      ],
                      "lists": [
                        2
                      ],
                      "remove_tags": [
                        5
                      ],
                      "remove_lists": [],
                      "auto_login": "no"
                    },
                    "notes": "Track users interested in upgrading",
                    "created_by": 1,
                    "created_at": "2024-06-20 14:00:00",
                    "updated_at": "2024-06-20 14:00:00",
                    "short_url": "https://example.com/?fluentcrm=1&route=smart_url&slug=x7y8z9"
                  },
                  "message": "SmartLink has be created"
                }
              }
            }
          },
          "422": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errors": {
                      "type": "object",
                      "description": "Map of field names to validation error messages.",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "errors": {
                    "title": [
                      "The title field is required."
                    ],
                    "target_url": [
                      "The target url field is required.",
                      "The target url format is invalid."
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "SmartLinkInput": {
        "type": "object",
        "description": "Input data for creating or updating a smart link.",
        "required": [
          "title",
          "target_url"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Display title of the smart link."
          },
          "target_url": {
            "type": "string",
            "format": "uri",
            "description": "The destination URL contacts are redirected to."
          },
          "actions": {
            "type": "object",
            "description": "Actions to apply when a contact clicks the link.",
            "properties": {
              "tags": {
                "type": "array",
                "description": "Tag IDs to add to the contact.",
                "items": {
                  "type": "integer"
                }
              },
              "lists": {
                "type": "array",
                "description": "List IDs to add the contact to.",
                "items": {
                  "type": "integer"
                }
              }
            }
          },
          "detach_actions": {
            "type": "object",
            "description": "Actions to remove when a contact clicks the link.",
            "properties": {
              "tags": {
                "type": "array",
                "description": "Tag IDs to remove from the contact.",
                "items": {
                  "type": "integer"
                }
              },
              "lists": {
                "type": "array",
                "description": "List IDs to remove the contact from.",
                "items": {
                  "type": "integer"
                }
              }
            }
          },
          "auto_login": {
            "type": "string",
            "description": "Whether to auto-login the WordPress user when they click the link.",
            "enum": [
              "yes",
              "no"
            ],
            "default": "no"
          },
          "notes": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional notes about the smart link."
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}