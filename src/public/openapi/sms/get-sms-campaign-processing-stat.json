{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/sms/campaigns/{id}/processing-stat": {
      "get": {
        "operationId": "getSmsCampaignProcessingStat",
        "summary": "GET Get SMS Campaign Processing Status",
        "description": "Get the processing status of an SMS campaign that is being prepared for sending. If the campaign is in `pending-scheduled` status and its scheduled time is within 6 minutes, it transitions to `processing`. Returns whether the client should reload for updated data. **PRO** (requires FluentCampaign Pro SMS module).",
        "tags": [
          "SMS"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "SMS campaign ID.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Processing status.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reload": {
                      "type": "boolean",
                      "description": "If `true`, the campaign is no longer processing and the client should reload the full status."
                    },
                    "campaign": {
                      "$ref": "#/components/schemas/SmsCampaign"
                    },
                    "didRun": {
                      "type": "boolean",
                      "description": "Whether any processing was done in this request (currently always `false` for SMS)."
                    },
                    "scheduling_method": {
                      "type": "string",
                      "description": "The sending type: `instant`, `schedule`, or empty string."
                    }
                  }
                },
                "example": {
                  "reload": false,
                  "campaign": {
                    "id": 5,
                    "title": "Summer Sale SMS",
                    "status": "processing",
                    "type": "campaign",
                    "recipients_count": 200
                  },
                  "didRun": false,
                  "scheduling_method": "schedule"
                }
              }
            }
          },
          "404": {
            "description": "Campaign not found."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "SmsCampaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "message_content": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "processing",
              "pending-scheduled",
              "scheduled",
              "working",
              "paused",
              "archived"
            ]
          },
          "type": {
            "type": "string"
          },
          "recipients_count": {
            "type": "integer"
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "settings": {
            "type": "object"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}