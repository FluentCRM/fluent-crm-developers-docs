{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/sms/campaigns/{id}/duplicate": {
      "post": {
        "operationId": "duplicateSmsCampaign",
        "summary": "POST Duplicate SMS Campaign",
        "description": "Create a duplicate of an existing SMS campaign. The new campaign is created in `draft` status with the title prefixed by `[Duplicate]`. Labels from the original campaign are copied to the duplicate. **PRO** (requires FluentCampaign Pro SMS module).",
        "tags": [
          "SMS"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "SMS campaign ID to duplicate.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign duplicated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaign": {
                      "$ref": "#/components/schemas/SmsCampaign"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "campaign": {
                    "id": 6,
                    "title": "[Duplicate] Summer Sale SMS",
                    "message_content": "Don't miss our summer sale!",
                    "status": "draft",
                    "type": "campaign",
                    "created_at": "2024-06-02 10:00:00",
                    "updated_at": "2024-06-02 10:00:00"
                  },
                  "message": "Campaign has been successfully duplicated"
                }
              }
            }
          },
          "404": {
            "description": "Campaign not found."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      },
      "SmsCampaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "message_content": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "processing",
              "pending-scheduled",
              "scheduled",
              "working",
              "paused",
              "archived"
            ]
          },
          "type": {
            "type": "string"
          },
          "recipients_count": {
            "type": "integer"
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "settings": {
            "type": "object"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}