{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCRM API",
    "description": "Complete REST API documentation for FluentCRM — a self-hosted email marketing and CRM plugin for WordPress.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-crm/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/cascade_selections": {
      "get": {
        "operationId": "getCascadeSelections",
        "summary": "GET Cascade Selections",
        "description": "Retrieve cascading selection options for a given provider. The response is generated by the `fluent_crm/cascade_selection_options_{provider}` filter, allowing third-party integrations to supply hierarchical option data. Returns an empty options array by default if no filter is registered for the given provider.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "provider",
            "in": "query",
            "description": "Provider identifier that determines which filter supplies the cascade options.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "woocommerce"
          }
        ],
        "responses": {
          "200": {
            "description": "Cascade selections retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "options": {
                      "type": "array",
                      "description": "Hierarchical options provided by the registered filter.",
                      "items": {
                        "type": "object"
                      }
                    },
                    "has_more": {
                      "type": "boolean",
                      "description": "Whether additional options are available beyond the returned set."
                    }
                  }
                },
                "example": {
                  "options": [],
                  "has_more": true
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}